{
  "name": "databar-mcp-server",
  "version": "1.4.0",
  "description": "MCP server for Databar.ai — enables AI assistants to run data enrichments, manage tables, and more",
  "main": "dist/index.js",
  "bin": {
    "databar-mcp-server": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http-server.ts",
    "watch": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "databar",
    "enrichment",
    "data-enrichment",
    "ai",
    "claude",
    "waterfall",
    "api"
  ],
  "author": "Databar.ai <info@databar.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/databar-ai/databar-mcp-server.git"
  },
  "homepage": "https://apiv3.databar.ai/mcp-server",
  "bugs": {
    "url": "https://github.com/databar-ai/databar-mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "minisearch": "^7.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
